# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in/intern
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up/intern
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/intern/onboarding

# Comma-separated emails that become admins after Clerk sign-in.
ADMIN_EMAILS=admin@example.com

# PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qa_internship_validator?schema=public"

# Optional admin helper for question suggestions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Optional Groq free-tier integration for admin attempt AI overview.
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local demo admin, credentials admin/admin. Disable in production.
DEMO_ADMIN_ENABLED=false
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD_HASH=pbkdf2_sha256:210000:efda5e6caf5bd8a568ac40b2a67c2481:67578dbfdb024a8d1aa90b6c2be7debc518d7ed562535690e9be11596c80dfff
DEMO_ADMIN_SESSION_SECRET=
INTERN_SESSION_SECRET=

# Intern invitation token lifetime in days.
INTERN_INVITATION_EXPIRES_IN_DAYS=14

# Used to encrypt invitation token values for admin-side copy actions.
INVITATION_TOKEN_ENCRYPTION_SECRET=
