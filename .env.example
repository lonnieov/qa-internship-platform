# App database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qa_internship_validator?schema=public"

# Auth/session secrets. Use different long random values in production.
ADMIN_SESSION_SECRET=
INTERN_SESSION_SECRET=

# Used to encrypt invitation token values for admin-side copy actions.
INVITATION_TOKEN_ENCRYPTION_SECRET=

# Comma-separated public hosts that may submit Next.js Server Actions behind a proxy.
# Render auto-provides RENDER_EXTERNAL_HOSTNAME; add custom domains here when needed.
SERVER_ACTIONS_ALLOWED_ORIGINS=

# Intern invitation token lifetime in days.
INTERN_INVITATION_EXPIRES_IN_DAYS=14

# Docker Compose defaults for the bundled Postgres service.
APP_PORT=3000
POSTGRES_DB=qa_internship
POSTGRES_USER=qa_user
POSTGRES_PASSWORD=qa_password
